-- 151. 모든 사원들의 사원번호, 부서번호, 부서명을 조회한다. 근무중인 부서가 없다면 null로 표시한다.
SELECT * 
  FROM EMPLOYEES E
  LEFT OUTER JOIN DEPARTMENTS D
    ON E.DEPARTMENT_ID = D.DEPARTMENT_ID
;
-- 152. 부서에서 근무하는 모든 사원들의 이름, 부서번호, 부서명을 조회한다. 근무중인 사원이 없다면 null로 표시한다.
SELECT *
  FROM DEPARTMENTS D
  LEFT OUTER JOIN EMPLOYEES E
    ON D.DEPARTMENT_ID = E.DEPARTMENT_ID
;
-- 153. 모든 부서의 부서장들의 사원번호, 이름, 성, 부서명을 조회한다. 부서장이 없다면 null로 표시한다.
SELECT D.MANAGER_ID 
	 , E.FIRST_NAME
	 , E.LAST_NAME
	 , D.DEPARTMENT_NAME 
  FROM DEPARTMENTS D
  LEFT OUTER JOIN EMPLOYEES E
    ON D.MANAGER_ID = E.EMPLOYEE_ID
; 
-- 154. 모든 지역에 존재하는 부서들의 도시명, 부서명을 조회한다. 부서가 없다면 null로 표시한다.
SELECT L.CITY
	 , D.DEPARTMENT_NAME 
	 , L.*
	 , D.*
  FROM LOCATIONS L
  LEFT OUTER JOIN DEPARTMENTS D
    ON L.LOCATION_ID = D.LOCATION_ID
;
-- 155. 모든 국가에 존재하는 도시명, 부서명을 조회한다. 도시 또는 부서가 없다면 null로 표시한다.
SELECT L.CITY
	 , D.DEPARTMENT_NAME 
  FROM COUNTRIES C
  LEFT OUTER JOIN LOCATIONS L
    ON C.COUNTRY_ID = L.COUNTRY_ID
  LEFT OUTER JOIN DEPARTMENTS D
    ON L.LOCATION_ID = D.LOCATION_ID
 ORDER BY L.CITY 
     , D.DEPARTMENT_NAME 
;
SELECT L2.CITY 
	 , L2.DEPARTMENT_NAME 
  FROM COUNTRIES C
  LEFT OUTER JOIN (SELECT COUNTRY_ID 
  						, CITY
  						, D.DEPARTMENT_NAME 
					 FROM LOCATIONS L
					 LEFT OUTER JOIN (SELECT LOCATION_ID 
					 					   , DEPARTMENT_NAME 
					 					FROM DEPARTMENTS) D
					   ON L.LOCATION_ID = D.LOCATION_ID) L2
	ON C.COUNTRY_ID = L2.COUNTRY_ID 
 ORDER BY L2.CITY
 	 , L2.DEPARTMENT_NAME 
;
-- 156. 모든 부서별로 근무하는 사원의 수를 조회한다. 근무중인 사원이 없다면 0으로 표시한다.
SELECT D.DEPARTMENT_NAME 
	 , COUNT(E.EMPLOYEE_ID) EMP_CNT
  FROM DEPARTMENTS D
  LEFT OUTER JOIN EMPLOYEES E
    ON D.DEPARTMENT_ID = E.DEPARTMENT_ID
 GROUP BY D.DEPARTMENT_NAME 
 ORDER BY D.DEPARTMENT_NAME 
;
-- 157. 모든 지역별로 근무하는 사원의 수를 조회한다. 근무중인 사원이 없아면 0으로 표시한다.
SELECT L.CITY 
	 , COUNT(E.EMPLOYEE_ID) EMP_CNT
  FROM LOCATIONS L
  LEFT OUTER JOIN DEPARTMENTS D
    ON L.LOCATION_ID = D.LOCATION_ID
  LEFT OUTER JOIN EMPLOYEES E
    ON D.DEPARTMENT_ID = E.DEPARTMENT_ID
 GROUP BY L.CITY
 ORDER BY L.CITY
;
-- 158. 모든 국가에 존재하는 부서의 수를 조회한다. 부서가 없다면 0으로 표시한다.
SELECT C.COUNTRY_NAME 
	 , COUNT(D.DEPARTMENT_ID) DEPT_CNT
  FROM COUNTRIES C
  LEFT OUTER JOIN LOCATIONS L
    ON C.COUNTRY_ID = L.COUNTRY_ID
  LEFT OUTER JOIN DEPARTMENTS D
    ON L.LOCATION_ID = D.LOCATION_ID
 GROUP BY C.COUNTRY_NAME 
 ORDER BY C.COUNTRY_NAME
 
;