CREATE TABLE BOARD.BOARD (
	ID VARCHAR2(18 CHAR) NOT NULL,
	TITLE VARCHAR2(200 CHAR) NOT NULL,
	CONTENT CLOB NULL,
	VIEW_COUNT NUMBER(8,0) DEFAULT 0 NOT NULL,
	WRITE_DATE DATE NOT NULL,
	LATEST_MODIFY_DATE DATE NULL,
	CONSTRAINT BOARD_PK PRIMARY KEY (ID)
)
TABLESPACE USERS;
COMMENT ON TABLE BOARD.BOARD IS '게시글의 목록';
COMMENT ON COLUMN BOARD.BOARD.ID IS '게시글의 아이디 (BO-YYYYMMDD-일련번호(6자리))';
COMMENT ON COLUMN BOARD.BOARD.TITLE IS '게시글의 제목';
COMMENT ON COLUMN BOARD.BOARD.CONTENT IS '게시글의 내용';
COMMENT ON COLUMN BOARD.BOARD.VIEW_COUNT IS '게시글의 조회수';
COMMENT ON COLUMN BOARD.BOARD.WRITE_DATE IS '게시글을 작성한 날짜와 시간';
COMMENT ON COLUMN BOARD.BOARD.LATEST_MODIFY_DATE IS '게시글을 마지막으로 수정한 시간';
