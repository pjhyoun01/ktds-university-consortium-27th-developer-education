INSERT INTO BOARD 
 (ID
, TITLE
, CONTENT
, WRITE_DATE) VALUES 
 ('BO-' || TO_CHAR(SYSDATE, 'YYYYMMDD-') || LPAD(SEQ_BOARD_PK.NEXTVAL, 6, '0')
, ''
, ''
, SYSDATE);

UPDATE BOARD                   
   SET TITLE = '수정된 제목'
     , CONTENT = '수정된 내용'
     , LATEST_MODIFY_DATE = SYSDATE
 WHERE ID = 'BO-20260303-000001';


DELETE
  FROM BOARD
 WHERE ID = ''
;

SELECT ID
	 , TITLE
	 , CONTENT
	 , VIEW_COUNT
	 , TO_CHAR(WRITE_DATE, 'YYYY-MM-DD HH24:MI:SS') AS WRITE_DATE 
	 , TO_CHAR(LATEST_MODIFY_DATE, 'YYYY-MM-DD HH24:MI:SS') AS LATEST_MODIFY_DATE 
  FROM BOARD
 WHERE ID = 'BO-20260303-000002'
;

