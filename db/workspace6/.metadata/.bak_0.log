!MESSAGE Error : 918, Position : 160, SQL = -- 150. 사원번호가 100번인 사원의 사원번호, 이름과 사원번호로 내림차순 정렬된 사원의 사원번호, 이름 조회한다.
SELECT EMPLOYEE_ID 
	 , FIRST_NAME 
  FROM EMPLOYEES E
 INNER JOIN (SELECT CASE 
			 		   WHEN EMPLOYEE_ID = 100 THEN 0 
			 		   ELSE 1 
			 	    END AS ORDER_CAL
			 	  , EMPLOYEE_ID 
 			   FROM EMPLOYEES) E2
    ON E.EMPLOYEE_ID = E2.EMPLOYEE_ID 
 ORDER BY ORDER_CAL ASC
