-- 수행하는 직무의 이름이 Finance Manager인 사원의 사번, 직무 아이디 조회
SELECT E.EMPLOYEE_ID 
	 , E.JOB_ID 
  FROM EMPLOYEES E
 WHERE E.JOB_ID = (SELECT J.JOB_ID 
 					 FROM JOBS J
